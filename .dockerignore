# Secrets — NEVER bake these. Judges paste their own key at runtime.
.env
.env.*

# Host build artifacts — must NOT enter the image (macOS-native binaries, stale builds).
**/node_modules
**/.next
**/.turbo
**/.cache
**/.transformers-cache
.git
*.log

# Source PDFs (dropped from git anyway) and the agent's runtime scratch aren't
# needed in the image — keep it lean.
data/pdfs
data/scratch

# NOTE: data/takt.db, data/products, data/pages, data/heroes and data/.enc-key are
# intentionally NOT ignored — the seeded catalog + product Profiles (OKF markdown)
# + rendered pages are baked in so the app answers on first boot.
