# ─── Required ─────────────────────────────────────────────────────────────
# The only key you need to run Takt locally. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your-api-key-here
OPENAI_API_KEY=            # optional: enables OpenAI models (gpt-5, gpt-5-mini, gpt-5-nano)
# ─── Optional (sensible local defaults; no need to set for local dev) ───────
# Where the web app reaches the agent service. Default works for `pnpm dev`.
AGENT_SERVICE_URL=http://localhost:8787
# Public origin of the web app (used to build absolute page-image / artifact URLs).
WEB_PUBLIC_URL=http://localhost:3000
# Ports
WEB_PORT=3000
AGENT_PORT=8787
# 32-byte hex key used to encrypt provider API keys at rest. Auto-generated and
# written to .env on first run if left blank. Set explicitly for stable storage.
TAKT_ENC_KEY=
# Shared secret the web proxy sends to the agent service (x-takt-secret). Leave
# blank for local dev (gate off — the agent only listens on localhost). Set it
# for any non-localhost deploy; the container auto-generates one if unset.
TAKT_AGENT_SECRET=
# Embedding model (local, downloaded once on first ingest/run). Override to swap.
TAKT_EMBED_MODEL=Xenova/bge-small-en-v1.5
MINIMAX_API_KEY=            # optional: enables MiniMax models (M3, M2.5)
