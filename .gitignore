# dependencies
node_modules
.pnpm-store

# builds
.next
dist
out
*.tsbuildinfo

# secrets — never commit
.env
.env.local
.env.*.local

# private notes — local only, never committed or uploaded
*.local.md

# generated data. The RUNTIME db holds the encrypted provider key + chat
# history, so it stays out of the repo. We DO commit a key-free pre-seeded
# template (data/seed.db) plus the static page/hero images, so a fresh clone
# runs with zero seeding (connection.ts copies seed.db -> prox.db on first boot).
# Rebuild the template after re-seeding with scripts/bake-seed-db.sh.
/data/*
!/data/.gitkeep
!/data/seed.db
!/data/pages/
!/data/heroes/
# never commit: runtime db, its sidecars, the encryption key, or ingest inputs
/data/prox.db
/data/prox.db-wal
/data/prox.db-shm
/data/.enc-key
/data/pdfs/

# local demo videos — embedded in the README via GitHub attachment URLs and
# Google Drive, not committed (walkthrough.mp4 alone is >100MB, over GitHub's limit)
/assets/Vids/

# caches
.turbo
.transformers-cache

# os / editor
.DS_Store
*.log
