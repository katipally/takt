# dependencies
node_modules
.pnpm-store

# builds
.next
dist
out
*.tsbuildinfo

# secrets — never commit
.env
.env.local
.env.*.local

# private notes — local only, never committed or uploaded
*.local.md

# Everything under data/ is machine-local and regenerable via `pnpm ingest
# <folder>`: the runtime DB (with your encrypted provider key + chats), the
# ingested product bundles (markdown + compiled index + media), rendered pages,
# and heroes. The repo ships an EMPTY catalog — a fresh clone ingests its own
# products (connection.ts creates an empty takt.db from the schema on first boot;
# no committed seed.db needed).
/data/*

# the full walkthrough is 144MB (over GitHub's 100MB limit) — it lives on Google
# Drive, linked from the README. The short feature clips are committed and embedded.
/assets/Vids/walkthrough.mp4

# caches
.turbo
.transformers-cache

# os / editor
.DS_Store
*.log
