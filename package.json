{
  "name": "takt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "bash scripts/free-ports.sh",
    "dev": "concurrently -k --kill-others -n web,agent -c cyan,magenta \"pnpm --filter @takt/web dev\" \"pnpm --filter @takt/agent dev\"",
    "stop": "bash scripts/free-ports.sh",
    "build": "pnpm -r --filter @takt/web build",
    "ingest": "pnpm --filter @takt/ingest start --",
    "db:reset": "pnpm --filter @takt/db reset",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.3"
  }
}
